# ============================================================
# Build #3: Medical Records AI Summarizer
# Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# The full system prompt for medical summarization
# Copy from prompts/system-prompt.md — paste as a single line with \n for newlines
# Or set as a multiline value in your n8n environment
SUMMARIZER_SYSTEM_PROMPT=You are a legal medical records analyst AI...

# ============================================================
# NCA Toolkit (no-code-architects-toolkit)
# ============================================================
NCA_TOOLKIT_URL=https://your-nca-toolkit-instance.com
NCA_TOOLKIT_API_KEY=your_nca_api_key_here

# ============================================================
# GoHighLevel (GHL)
# ============================================================
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_location_id_here
GHL_ATTORNEY_EMAIL=attorney@yourfirm.com

# ============================================================
# n8n Webhook URLs
# (Generated when you activate workflows in n8n)
# ============================================================
N8N_PDF_INTAKE_WEBHOOK=https://your-n8n.com/webhook/pdf-intake
N8N_SUMMARY_DELIVERY_WEBHOOK=https://your-n8n.com/webhook/summary-delivery

# ============================================================
# Email (SMTP) - for attorney summary delivery
# ============================================================
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=cases@yourfirm.com
FROM_NAME=Medical Records AI

# ============================================================
# File Storage (Optional - for archiving processed PDFs)
# ============================================================
# AWS S3 (if storing processed records)
S3_BUCKET=your-medical-records-bucket
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ============================================================
# GHL Custom Field Keys
# (Must match exactly what you created in GHL Settings)
# ============================================================
GHL_FIELD_CASE_NAME=case_name
GHL_FIELD_CLAIM_TYPE=claim_type
GHL_FIELD_SUMMARY_STATUS=summary_status
GHL_FIELD_SUMMARY_GENERATED_AT=summary_generated_at
GHL_FIELD_SUMMARY_TEXT=summary_text
GHL_FIELD_SUMMARY_WORD_COUNT=summary_word_count

# ============================================================
# Processing Settings
# ============================================================
# Max characters per GPT-4o chunk (leave at 80000 for safety)
MAX_CHUNK_CHARS=80000

# Processing timeout in milliseconds
NCA_TIMEOUT_MS=120000
OPENAI_TIMEOUT_MS=180000

# ============================================================
# Monitoring (Optional)
# ============================================================
# Webhook URL for error alerts (e.g., Slack, Discord, or monitoring service)
ERROR_ALERT_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx
